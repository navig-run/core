# ─────────────────────────────────────────────────────────────────────────────
# NAVIG — Developer / Docker / CI Environment Overrides
#
# ⚠  REGULAR USERS: you do not need this file.
#    Run `navig init` to configure NAVIG.  Settings are stored in:
#      ~/.navig/config.yaml          (edit freely)
#      ~/.navig/vault/vault.db       (secrets — managed by `navig vault`)
#    For a human-friendly config reference, see:
#      config/config.example.yaml   (copy → ~/.navig/config.yaml)
#
# This file is for:
#   • Contributors running the test suite locally
#   • Docker Compose / CI deployments (see deploy/.env.example)
#   • Advanced operators who need env-level overrides above config.yaml
#
# Resolution order (highest → lowest priority):
#   1. Environment variable / .env  ← this file
#   2. ~/.navig/config.yaml         ← normal user config
#   3. .navig/config.yaml           ← project-local override
#   4. config/defaults.yaml         ← factory defaults (do not edit)
# ─────────────────────────────────────────────────────────────────────────────


# ── Gateway ──────────────────────────────────────────────────────────────────
# The main NAVIG local gateway server port.
# All local CLI commands (navig cron, navig flux, navig status…) connect here.
# Canonical config key: gateway.port
# NAVIG_GATEWAY_PORT=8789


# ── Forge Bridge (VS Code MCP) ───────────────────────────────────────────────
# WebSocket port for the navig-bridge VS Code extension MCP bridge.
# Only change this if you have patched the extension to use a different port.
# Canonical config key: none (constant in bridge_grid_reader.py)
# NAVIG_FORGE_PORT=42070


# ── Browser Automation Daemon ────────────────────────────────────────────────
# TCP port for the Go browser automation daemon (host/run_task.go).
# Used by: navig webhook, navig integrations browser
# Canonical config key: daemon.browser_port
# NAVIG_BROWSER_DAEMON_PORT=7421


# ── Mesh Multicast ───────────────────────────────────────────────────────────
# LAN multicast group/port for NAVIG mesh peer discovery.
# Change in restricted enterprise networks that block the default addresses.
# Canonical config key: none (env-only)
# NAVIG_MESH_MULTICAST_GROUP=224.0.0.251
# NAVIG_MESH_MULTICAST_PORT=5354


# ── Identity / Latency Probe ─────────────────────────────────────────────────
# Host used to measure network latency shown in `navig status`.
# Replace with an intranet IP in air-gapped environments.
# Canonical config key: identity.latency_probe_host
# NAVIG_LATENCY_PROBE_HOST=8.8.8.8


# ── TTS (Text-to-Speech) ─────────────────────────────────────────────────────
# OpenAI TTS model and voice used when Telegram voice replies are enabled.
# See available voices: https://platform.openai.com/docs/guides/text-to-speech
# Canonical config key: none (env-only)
# NAVIG_TTS_MODEL=tts-1
# NAVIG_TTS_VOICE=nova


# ── NAVIG Mini Agent ─────────────────────────────────────────────────────────
# Connection settings for your personal NAVIG Mini device (NAS, Pi, etc.).
# Set via: navig config set mini.url http://my-nas:9191
# Canonical config key: mini.url, mini.ssh_host, mini.secret
# MINI_AGENT_URL=http://your-mini-host:9191
# MINI_SSH_HOST=your-mini-hostname
# MINI_AGENT_SECRET=your_shared_hmac_secret


# ─────────────────────────────────────────────────────────────────────────────
# AI PROVIDERS  (set during `navig init` — stored in vault, not here)
# The keys below are read as fallback if not found in the vault.
# Prefer storing secrets in the vault: navig vault set openai_api_key <value>
# ─────────────────────────────────────────────────────────────────────────────

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
# DEEPGRAM_API_KEY=...
# ELEVENLABS_API_KEY=...
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json


# ─────────────────────────────────────────────────────────────────────────────
# TELEGRAM  (set during `navig init`)
# ─────────────────────────────────────────────────────────────────────────────

# TELEGRAM_BOT_TOKEN=123456:ABC-...
# NAVIG_TELEGRAM_ALLOWED_USERS=111111111,222222222


# ─────────────────────────────────────────────────────────────────────────────
# DISCORD  (optional)
# ─────────────────────────────────────────────────────────────────────────────

# DISCORD_BOT_TOKEN=...


# ─────────────────────────────────────────────────────────────────────────────
# MEDIA / AUDIO  (optional enrichment features)
# ─────────────────────────────────────────────────────────────────────────────

# AUDD_API_KEY=...
# SPOTIFY_CLIENT_ID=...
# SPOTIFY_CLIENT_SECRET=...
# LASTFM_API_KEY=...
# SERPAPI_KEY=...


# ─────────────────────────────────────────────────────────────────────────────
# DEBUG / DEVELOPMENT
# ─────────────────────────────────────────────────────────────────────────────

# NAVIG_LOG_LEVEL=info        # debug | info | warning | error
# NAVIG_DEBUG=0               # set to 1 to enable debug logging to ~/.navig/debug.log
