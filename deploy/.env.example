# ─────────────────────────────────────────────────────────────
# NAVIG Stack — Environment Configuration
# Copy to .env and edit values before running docker compose
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=navig
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=navig
# Bind to localhost only (production). Use 0.0.0.0:5432 for dev.
POSTGRES_PORT=127.0.0.1:5432

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=127.0.0.1:6379
REDIS_MAXMEMORY=256mb

# ── Ollama ────────────────────────────────────────────────────
OLLAMA_PORT=127.0.0.1:11434
OLLAMA_KEEP_ALIVE=5m
# OLLAMA_GPU_DRIVER=nvidia  # Uncomment if GPU available

# ── NAVIG Application ────────────────────────────────────────
NAVIG_DB_HOST=postgres
NAVIG_DB_PORT=5432
NAVIG_DB_NAME=navig
NAVIG_DB_USER=navig
NAVIG_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
NAVIG_REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
NAVIG_OLLAMA_URL=http://ollama:11434
NAVIG_LOG_LEVEL=info

# ── Optional: Gateway ────────────────────────────────────────
# NAVIG_GATEWAY_PORT=7777
# NAVIG_GATEWAY_HOST=0.0.0.0
# NAVIG_TELEGRAM_TOKEN=your_bot_token
# NAVIG_OPENROUTER_KEY=your_openrouter_key
