# Copy this file to .env before first start (installer does this automatically).

# Matrix server domain visible in Matrix IDs (e.g., @bot:navig.local)
SYNAPSE_SERVER_NAME=navig.local

# Synapse HTTP listener port on localhost
SYNAPSE_PORT=8008

# yes|no
SYNAPSE_REPORT_STATS=no

# Secret used by register_new_matrix_user and admin registration APIs
# Replace with a long random value in real deployments.
SYNAPSE_REGISTRATION_SHARED_SECRET=change-me
