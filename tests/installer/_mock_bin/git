#!/usr/bin/env bash
# Mock git binary for installer tests
case "${1}" in
    --version) echo "git version 2.43.0"; exit 0 ;;
    clone)
        # $2 = URL, $3 = destination
        dest="${3:-navig}"
        mkdir -p "$dest/.git"
        echo "Cloning into '$dest'..."
        exit 0
        ;;
    -C)
        # git -C <dir> <subcommand>
        shift; shift   # drop -C <dir>
        case "${1}" in
            status) echo ""; exit 0 ;;
            pull)   echo "Already up to date."; exit 0 ;;
            *)      exit 0 ;;
        esac
        ;;
    *) exit 0 ;;
esac
