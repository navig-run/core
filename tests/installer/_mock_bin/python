#!/usr/bin/env bash
# Mock python binary for installer tests
case "${1}" in
    --version | -V)   echo "Python 3.11.9"; exit 0 ;;
    -m)
        case "${2}" in
            site)   echo "$HOME/.local"; exit 0 ;;
            pip)    shift 2; exec "$0" "$@" ;;  # delegate: python -m pip → this stub
            *)      exit 0 ;;
        esac
        ;;
    *)  exit 0 ;;
esac
