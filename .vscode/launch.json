{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run NAVIG Bridge Extension (Dev)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/packages/navig-bridge"
			],
			"outFiles": [
				"${workspaceFolder}/packages/navig-bridge/out/**/*.js"
			],
			"preLaunchTask": "watch-navig-bridge",
			"sourceMaps": true
		},
		{
			"name": "Run NAVIG Bridge Extension (No Watch)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/packages/navig-bridge"
			],
			"outFiles": [
				"${workspaceFolder}/packages/navig-bridge/out/**/*.js"
			],
			"preLaunchTask": "compile-navig-bridge",
			"sourceMaps": true
		}
	]
}
