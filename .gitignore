# ===============================================
# NAVIG CLI - Git Ignore Configuration
# ===============================================
# This file specifies intentionally untracked files that Git should ignore.
# See: https://git-scm.com/docs/gitignore

# ===============================================
# IDE and Editor Files
# ===============================================
.vscode/                    # VS Code settings
.idea/                      # JetBrains IDEs (PyCharm, IntelliJ)
*.swp                       # Vim swap files
*.swo                       # Vim swap files
*~                          # Backup files
.DS_Store                   # macOS Finder metadata
Thumbs.db                   # Windows thumbnail cache
desktop.ini                 # Windows folder settings
nul                         # Windows NUL device artifact

# ===============================================
# Dev scripts generated during agent sessions
# ===============================================
validate_prompts.py
track_c_results.txt

# ===============================================
# Python
# ===============================================
__pycache__/                # Python bytecode cache
**/__pycache__/             # Python bytecode cache (any depth)
**/__pycache__              # Python bytecode cache (no trailing slash variant)
*.py[cod]                   # Compiled Python files
*$py.class                  # Python class files
*.so                        # Shared objects
.Python                     # Python environment
build/                      # Build directory
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
venv/
ENV/
env/
.venv
pip-log.txt
pip-delete-this-directory.txt

# Linting and Type Checking
.ruff_cache/                # Ruff linter cache
.mypy_cache/                # mypy type checker cache
.dmypy.json                 # dmypy metadata
dmypy.json
.pyre/                      # Pyre type checker
.pytype/                    # Pytype static analyzer

# ===============================================
# PowerShell
# ===============================================
*.ps1xml                    # PowerShell XML files (unless explicitly needed)
*.psd1                      # PowerShell data files (config-dependent)

# ===============================================
# PHP and Composer
# ===============================================
vendor/                     # Composer dependencies
composer.phar               # Composer executable
composer.lock               # Lock file (uncomment if not needed for your workflow)
*.cache                     # PHP cache files

# ===============================================
# Node.js (if used)
# ===============================================
node_modules/               # npm dependencies
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json           # npm lock file (uncomment if not needed)

# ===============================================
# Database Files
# ===============================================
*.sql                       # SQL dump files (except migrations)
!migrations/*.sql           # Keep migration files
*.sqlite
*.sqlite3
*.db
*.dump                      # Database dumps

# ===============================================
# Logs and Temporary Files
# ===============================================
*.log                       # All log files
*.tmp                       # Temporary files
*.temp                      # Temporary files
*.cache                     # Cache files
logs/                       # Log directories
*.pid                       # Process ID files

# ===============================================
# Sensitive Data and Credentials
# ===============================================
.env                        # Environment variables
.env.*                      # Environment-specific files
!.env.example               # Keep example env file
!.env.*.example             # Keep example env files (e.g. .env.telegram.example)

# ===============================================
# Experimental and Lab Projects
# ===============================================
.lab/                       # Experimental projects and prototypes
*.key                       # Private keys
*.pem                       # SSL/TLS certificates
*.crt                       # Certificate files
*.p12                       # PKCS12 files
*.pfx                       # Certificate files
secrets.yaml
credentials.json
config/secrets.*
*_credentials.*

# Discord Credentials (NEVER commit these)
discord-webhooks.json       # Webhook URLs
*.token                     # Bot tokens
discord-*.json              # Discord config with secrets

# NAVIG Vault & Encrypted Data (NEVER commit)
*.enc                       # AES-256 encrypted vault blobs
.blackbox/                  # Vault key directory
**/.blackbox/               # Vault key directory (any depth)
vault.salt                  # Vault salt file

# Cython compiled binaries (generated at build time, not committed)
*.pyd                       # Cython/C extension - Windows
# *.so compiled by Cython are already covered by *.so above

# NAVIG Configuration
# ~/.navig/ is the global user store - never in a repo
~/.navig/                   # Global user NAVIG config (shouldn't be in repo anyway)
# .navig/ is TRACKED - plans/, brand/, wiki/, agents/ all live here
# Only runtime / credential files inside it are ignored (see list below)
.archive/                   # Local archive folder
nohup.out                   # Background process output

# ===============================================
# Backups and Archives
# ===============================================
.backups/                   # Backup directory
.backup/                    # Local backup folder (singular)
*.backup                    # Backup files
*.bak                       # Backup files
*.INSECURE.bak              # Security-removed code backups
*.zip                       # Archives
*.tar.gz                    # Compressed archives
*.tgz                       # Compressed archives
*.rar                       # Archives
*-upload.tgz                # Upload artifacts

# ===============================================
# Testing and Coverage
# ===============================================
.pytest_cache/              # Pytest cache
.coverage                   # Coverage data
htmlcov/                    # HTML coverage reports
.tox/                       # Tox testing
.nox/                       # Nox sessions
coverage.xml                # Coverage XML report
*.cover                     # Coverage files
.hypothesis/                # Hypothesis test data

# ===============================================
# Documentation Build Artifacts
# ===============================================
docs/_build/                # Sphinx build directory
site/                       # MkDocs build directory

# ===============================================
# App-Specific
# ===============================================

# Documentation and Tests (tracked - essential to the project)
# docs/
# tests/

# ===============================================
# OS-Specific
# ===============================================
# macOS
.AppleDouble
.LSOverride
._*

# Windows
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
.directory
.Trash-*

# ===============================================
# Miscellaneous
# ===============================================
*.orig                      # Merge conflict originals
cython_debug/               # Cython debug symbols

# ===============================================
# END OF .gitignore
# ===============================================

# NAVIG runtime files inside
.navig/
.backups/
node_modules

# AI IDE Configuration
# Per-developer overrides only:
.augment
.clinerules
.cursorrules
.windsurfrules
.agent/
.agents/
.claude/
.codex/
.gemini/
.ruff_cache/

# Archive (cleanup staging - never commit)
.archive/

# Bot stack (separate private repo)
navig_ai.py
navig_bot.py
run_navig.py
navig_harness.py
requirements-bot.txt

# Private files
knowledge/
.env.remote

# NAVIG reports (security scans, secret scans - never commit)
.navig/reports/

# Dev scratch / test output files in repo root (never commit)
out*.txt
exec_res.txt
vault_res.txt
debug.txt
dev.log
profile.txt
cprof.log
cumtime_profile.txt
version_prof*.txt
import_times.log
test_out*.txt
test_results*.txt
test_failures*.txt
test_run.log
test_vault.log
failed_test*.txt
raw_out.txt
cli_analysis.txt

# Root-level dev scratch scripts (one-off, not part of package)
analyze_cli.py
clean_mcp.py
fix_db_aliases.py
fix_imports.py
move_apps.py
move_host.py
run_test.py
test_google.py
test_json.py
test_parse*.py
patch_wizard.py
patch2_wizard.py
patch3_wizard.py
fix_escapes.py
fix_escapes2.py
audit_prompts.py
audit_slugs.py
validate_prompts.py
_msg_rewrite.py
_rewrite_history.py
audit_log.txt

# Root output / tracking files
latest.json                 # Stale release metadata artifact
pytest_fail.txt
tC_out*.txt
track_c_results.txt
STABILITY_REPORT.md

# Internal step-completion reports (not relevant to contributors)
docs/.archive/
test_vision.py

temp_restore/

# Runtime local data (user-specific, not for VCS)
userdata/

# host/ - compiled binaries and runtime logs
host/out.log
host/build_errors.txt
host/*.exe

# Community stub folder (separate repo at navig-community/)
navig-community/

# Runtime store - live content lives in ~/.navig/store/, not in VCS
store/

# icons/ was moved to .navig/brand/ (tracked); ignore any root-level recreation
icons/

# Private dev-only plugin - never commit
navig/plugins/llm_bridge/
navig/plugins/llm-bridge/

# Rust
host/crates/**/target/
**/target/

# Local workspace
.local/
$null

# pytest local temp dirs
.pytest_tmp/
