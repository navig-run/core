# Root output / tracking files
audit_log.txt               # Agent session audit log вЂ” user-specific
ft4.txt                     # Dev scratch output
latest.json                 # Stale release metadata artifact
pytest_fail.txt
tC_out*.txt
track_c_results.txt
STABILITY_REPORT.md

# Internal step-completion reports (not relevant to contributors)
docs/.archive/
test_vision.py

temp_restore/

# Runtime local data (user-specific, not for VCS)
userdata/

# host/ вЂ” compiled binaries and runtime logs
host/out.log
host/build_errors.txt
host/*.exe

# Community stub folder (separate repo at navig-community/)
navig-community/

# store/ at repo root is the built-in content package store вЂ” it IS tracked.
# Only exclude generated/runtime artifacts within it if they appear:
store/cache/
store/tmp/
store/*.log

# icons/ was moved to .navig/brand/ (tracked); ignore any root-level recreation
icons/

# Private dev-only plugin вЂ” never commit
navig/plugins/llm_bridge/
navig/plugins/llm-bridge/

# Rust/Cargo build outputs
host/crates/**/target/
nohup.out
*.pdb


# Root internal operational files (moved to .navig/)
BOOTSTRAP_REPORT.md
NEXT_ACTIONS.md
GITHUB_MANUAL_OR_CLI_STEPS.md
BRAND_USAGE.md
OFFICIAL_BUILDS.md
audit_log.txt
nohup.out

