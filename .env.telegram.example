# NAVIG Telegram Bot - Configuration Template
# Copy this file to .env and fill in your credentials

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI Model (uses NAVIG's configured providers)
# Options: openrouter, openai, anthropic, groq, ollama
# Configure providers with: navig ai providers --add openrouter
NAVIG_AI_MODEL=openrouter

# Path to NAVIG executable (default: navig)
NAVIG_PATH=navig

# Allowed Telegram Users (comma-separated user IDs)
# Leave empty to allow all users (NOT RECOMMENDED for security)
# Get your user ID by sending /start to the bot
ALLOWED_TELEGRAM_USERS=123456789,987654321

# Typing Indicator Mode (OpenClaw-style)
# Options: instant, message, never
# - instant: Show typing immediately when processing starts (default)
# - message: Show typing only when generating response
# - never: Disable typing indicators
TYPING_MODE=instant

# Typing indicator refresh interval in seconds (default: 4.0)
# Telegram typing indicators expire after ~5 seconds
TYPING_INTERVAL=4.0
