{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "id",
    "name",
    "runtime"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "runtime": {
      "type": "string"
    },
    "inputs": {
      "type": "array"
    },
    "outputs": {
      "type": "array"
    }
  }
}